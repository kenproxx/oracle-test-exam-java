# App
NUXT_PUBLIC_APP_NAME=Oracle Java Exam Prep
NUXT_PUBLIC_FREE_MOCK_LIMIT=2

# Security
AES_KEY=change-me-to-32-plus-characters
TOKEN_SECRET=change-me-too
PASS_THRESHOLD=70

# Question source
# Can be a public JSON endpoint with either:
# 1) {"questions": [...]}
# 2) {"ocp-17": {"questions": [...]}, ...}
# 3) [...]
GOOGLE_SHEET_URL=

# Optional Google Apps Script endpoint for read/write user data
# Expected POST body:
# { action: "read"|"write", table: string, rows?: any[] }
# Expected response:
# { ok: true, rows: any[] }
GOOGLE_APPS_SCRIPT_URL=
